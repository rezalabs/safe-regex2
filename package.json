    "@rezalabs/ret": "^1.0.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "neostandard": "^0.13.0",
    "tstyche": "^7.0.0"
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm run test:unit && npm run test:typescript",
    "test:typescript": "tstyche",
    "test:unit": "node --experimental-test-coverage --test-coverage-lines=99 --test-coverage-functions=99 --test-coverage-branches=90 --test"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/rezalabs/safe-regex2.git"
  },
